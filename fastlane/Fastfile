default_platform(:ios)

platform :ios do
  # Auth via App Store Connect API key (recommended for CI). Falls back to
  # Apple ID + app-specific-password / interactive 2FA if ASC_KEY_ID unset.
  def asc_api_key
    return nil unless ENV["ASC_KEY_ID"]
    app_store_connect_api_key(
      key_id: ENV["ASC_KEY_ID"],
      issuer_id: ENV["ASC_ISSUER_ID"],
      key_filepath: ENV["ASC_KEY_PATH"]
    )
  end

  desc "Build and upload a new build to TestFlight"
  lane :beta do
    key = asc_api_key

    next_build_number = latest_testflight_build_number(
      app_identifier: "SWS.ProgYog",
      api_key: key
    ) + 1
    increment_build_number(build_number: next_build_number)

    build_app(
      scheme: "ProgYog",
      export_method: "app-store",
      output_directory: "./build",
      clean: true
    )

    upload_to_testflight(
      api_key: key,
      skip_waiting_for_build_processing: true
    )
  end
end
